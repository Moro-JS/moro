#!/bin/sh

# nvm refuses to load when npm_config_prefix is set (npm sets this when
# running scripts under a Homebrew-installed node). Clear it before sourcing
# nvm so commits triggered from `npm run` (e.g. release scripts) don't fail
# with "nvm is not compatible with the npm_config_prefix environment variable".
unset npm_config_prefix
unset PREFIX

# Load nvm if it exists
if [ -f ~/.nvm/nvm.sh ]; then
  . ~/.nvm/nvm.sh
fi

# GUI git clients (VS Code Source Control, etc.) launch hooks WITHOUT the
# shell's PATH, and nvm only helps if its default alias resolves. If npx still
# isn't found, fall back to the newest installed node (nvm dirs, then Homebrew
# / system locations) so commits work from any client.
if ! command -v npx >/dev/null 2>&1; then
  for d in "$HOME/.nvm/versions/node"/*/bin /opt/homebrew/bin /usr/local/bin; do
    [ -x "$d/npx" ] && NODE_BIN="$d"
  done
  [ -n "$NODE_BIN" ] && PATH="$NODE_BIN:$PATH"
fi

npx lint-staged
